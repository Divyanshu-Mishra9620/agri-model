# Serving config for serve.py (the FastAPI wrapper around DiseasePredictor).
# Copy to .env and fill in. Not used by the training pipeline itself.

# Path to the exported model. Relative paths resolve against the `ml/`
# working directory serve.py is expected to run from.
ML_MODEL_PATH=outputs/export/model.torchscript.pt

# Shared secret the RAG service must send on the X-API-Key header. Required —
# every /predict request is rejected if this is unset. Generate with e.g.
# `python -c "import secrets; print(secrets.token_hex(32))"` and copy the same
# value into the RAG service's ML_SERVICE_API_KEY (see
# "Retrieval aug gen/rag/.env.example").
ML_SERVICE_API_KEY=

# Only read by `python serve.py` directly (not by uvicorn CLI invocations).
ML_SERVICE_PORT=8500

# Only needed for deployment (see render.yaml / scripts/fetch_model.sh), not
# local dev. The exported model (~112MB) exceeds GitHub's 100MB push limit and
# isn't committed to this repo — this must be the download URL of a GitHub
# Release asset containing model.torchscript.pt, e.g.:
#   https://github.com/<owner>/<repo>/releases/download/<tag>/model.torchscript.pt
# See render.yaml's buildCommand, which runs scripts/fetch_model.sh at deploy
# time to fetch it from here into ML_MODEL_PATH before starting the server.
MODEL_DOWNLOAD_URL=
